---
import "@/styles/global.css";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";

type Props = {
  title?: string;
};

const { title = "Bible Games" } = Astro.props;
const pathname = Astro.url.pathname;
const brandThemeClass = pathname.includes("/games/coloring-pages")
  ? "brand-coloring-pages"
  : pathname.includes("/games/cryptogram/")
    ? "brand-cryptogram"
    : pathname.includes("/games/verse-unscramble/")
      ? "brand-verse-unscramble"
      : pathname.includes("/games/bible-wordle")
        ? "brand-bible-wordle"
        : pathname.includes("/games/word-search/")
          ? "brand-word-search"
          : "brand-default";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="shortcut icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <title>{title}</title>
  </head>
  <body class={brandThemeClass}>
    <Header />
    <main class="shell">
      <slot />
    </main>
    <Footer />
  </body>
</html>
