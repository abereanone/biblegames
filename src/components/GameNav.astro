---
type Props = {
  difficulty?: string;
  bookCode?: string;
  chapter?: number | string;
  verseKey?: string;
  collapsedOnMobile?: boolean;
};

const {
  difficulty = "medium",
  bookCode = "gen",
  chapter = 1,
  verseKey = "",
  collapsedOnMobile = true,
} = Astro.props;

const chapterPath = `${difficulty}/${bookCode}/${chapter}`;
const verseQuery = verseKey ? `?verse=${encodeURIComponent(verseKey)}` : "";
---

<section class:list={["panel", "no-print", "game-nav-panel", { "mobile-collapsible": collapsedOnMobile, "is-open": !collapsedOnMobile }]}>
  <button class="game-nav-toggle" type="button" aria-expanded="false">
    Show Games
  </button>

  <div class="button-row game-nav-links">
    <a class="btn game-btn" data-game="word-search" href={`/games/word-search/${chapterPath}`}>
      Word Search
    </a>
    <a class="btn game-btn" data-game="cryptogram" href={`/games/cryptogram/${chapterPath}${verseQuery}`}>
      Cryptogram
    </a>
    <a class="btn game-btn" data-game="verse-unscramble" href={`/games/verse-unscramble/${chapterPath}${verseQuery}`}>
      Verse Unscramble
    </a>
    <a class="btn game-btn" data-game="coloring-pages" href="/games/coloring-pages">
      Coloring Pages
    </a>
    <a class="btn game-btn" data-game="bible-wordle" href="/games/bible-wordle">
      Bible Verse Wordle
    </a>
  </div>
</section>

<script>
  for (const panel of document.querySelectorAll(".game-nav-panel")) {
    const toggle = panel.querySelector(".game-nav-toggle");

    if (!(toggle instanceof HTMLButtonElement)) {
      continue;
    }

    toggle.addEventListener("click", () => {
      const isOpen = panel.classList.toggle("is-open");
      toggle.setAttribute("aria-expanded", String(isOpen));
      toggle.textContent = isOpen ? "Hide Games" : "Show Games";
    });
  }
</script>
