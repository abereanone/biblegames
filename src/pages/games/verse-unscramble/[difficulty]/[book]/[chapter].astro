---
import Main from "@/layouts/Main.astro";
import { getBibleData, getChapter } from "@/lib/bible/data";
import { DIFFICULTIES, DIFFICULTY_LABELS, parseDifficulty } from "@/lib/games/difficulty";
import { buildVerseUnscramble, pickUnscrambleVerse } from "@/lib/games/verseUnscramble";
import GameNav from "@/components/GameNav.astro";

export async function getStaticPaths() {
  const bible = await getBibleData();

  return DIFFICULTIES.flatMap((difficulty) =>
    bible.books.flatMap((book) =>
      Array.from({ length: book.chapterCount }, (_, index) => ({
        params: {
          difficulty,
          book: book.code,
          chapter: String(index + 1),
        },
      }))
    )
  );
}

const difficulty = parseDifficulty(String(Astro.params.difficulty ?? "medium"));
const rawBook = String(Astro.params.book ?? "").toLowerCase();
const rawChapter = Number(Astro.params.chapter ?? "0");
const chapterData = await getChapter(rawBook, rawChapter);
const requestedVerseKey = String(Astro.url.searchParams.get("verse") ?? "").trim();
const bibleData = await getBibleData();
const books = bibleData.books;
const selectedBookCode = chapterData?.bookCode ?? rawBook;
const selectedBook = books.find((book) => book.code === selectedBookCode) ?? books[0];
const selectedChapter = chapterData?.chapter ?? 1;

const verseOptions = chapterData
  ? chapterData.verses.map((verse) => ({
      key: verse.key,
      reference: verse.reference,
      text: verse.text,
    }))
  : [];

const defaultVerse = chapterData ? pickUnscrambleVerse(chapterData.verses, difficulty) : null;
const selectedVerse =
  chapterData?.verses.find((verse) => verse.key === requestedVerseKey) ??
  defaultVerse ??
  chapterData?.verses[0] ??
  null;
const selectedVerseKey = selectedVerse?.key ?? "";
const puzzle = selectedVerse ? buildVerseUnscramble(selectedVerse, difficulty) : null;
const title = chapterData
  ? `Verse Unscramble (${difficulty}) | ${chapterData.bookName} ${chapterData.chapter}`
  : "Verse Unscramble | Chapter Not Found";
const defaultClueCount = difficulty === "easy" ? 1 : 0;
const defaultHideWordBank = difficulty !== "easy";

const difficultyLinks = DIFFICULTIES.map((value) => ({
  value,
  label: DIFFICULTY_LABELS[value],
  href: chapterData
    ? `/games/verse-unscramble/${value}/${chapterData.bookCode}/${chapterData.chapter}${
        selectedVerseKey ? `?verse=${encodeURIComponent(selectedVerseKey)}` : ""
      }`
    : "/",
}));

---

<Main title={title}>
  <GameNav theme="word-search" />

  <section class="panel game-theme theme-verse-unscramble">
    {chapterData && selectedVerse && puzzle ? (
      <>
        <h1 class="title">Verse Unscramble</h1>

        <div class="button-row no-print">
          {difficultyLinks.map((entry) => (
            <a class={`btn ${entry.value === difficulty ? "" : "alt"}`} href={entry.href} data-keep-verse-link>
              {entry.label}
            </a>
          ))}
        </div>

        <div class="field-grid chapter-jump-grid verse-unscramble-picker-row no-print">
          <div>
            <select id="vu-testament-select" name="vu-testament" aria-label="Filter books by testament">
              <option value="all" selected>ALL</option>
              <option value="ot">OT</option>
              <option value="nt">NT</option>
            </select>
          </div>
          <div>
            <select id="vu-book-select" name="vu-book">
              {books.map((book) => (
                <option value={book.code} selected={book.code === selectedBook?.code}>{book.name}</option>
              ))}
            </select>
          </div>
          <div>
            <select id="vu-chapter-select" name="vu-chapter">
              {Array.from({ length: selectedBook?.chapterCount ?? 1 }, (_, index) => {
                const chapter = index + 1;
                return <option value={chapter} selected={chapter === selectedChapter}>{chapter}</option>;
              })}
            </select>
          </div>
          <div>
            <select id="vu-verse-select" name="vu-verse">
              {verseOptions.map((verse) => (
                <option value={verse.key} selected={verse.key === selectedVerseKey}>{verse.reference}</option>
              ))}
            </select>
          </div>
        </div>
        <div class="field-grid vu-tools-row no-print">
          <div class="vu-clue-control">
            <select id="vu-clue-count-select">
              {Array.from({ length: 6 }, (_, index) => (
                <option value={index} selected={index === defaultClueCount}>
                  {`${index} ${index === 1 ? "Clue" : "Clues"}`}
                </option>
              ))}
            </select>
          </div>
          <div class="vu-print-control">
            <button type="button" onclick="window.__bgPrint ? window.__bgPrint(event) : window.print()">Print this Puzzle!</button>
          </div>
        </div>

        <p class="no-print print-orientation-tip">Print tip: set orientation to Portrait for Verse Unscramble pages.</p>

        <div class="unscramble-sheet">
          <ul id="vu-unscramble-grid" class="unscramble-grid" aria-label="Verse unscramble worksheet">
            {puzzle.words.map((entry) => (
              <li class="unscramble-item">
                <div class="scramble-cell">{entry.scrambled}</div>
                <div class="answer-cell">
                  <span class={`answer-line ${entry.length >= 12 ? "ultra" : entry.length >= 10 ? "tight" : entry.length >= 8 ? "compact" : ""}`}>
                    {Array.from({ length: entry.length }, (_, slotIndex) => (
                      defaultClueCount > 0 && slotIndex === entry.hintIndex ? (
                        <span class="hint-slot">{entry.hintLetter}</span>
                      ) : (
                        <span class="answer-slot" aria-hidden="true"></span>
                      )
                    ))}
                  </span>
                </div>
              </li>
            ))}
          </ul>
        </div>

        <label class="answer-toggle vu-word-bank-toggle no-print" for="vu-hide-word-bank">
          <input id="vu-hide-word-bank" type="checkbox" checked={defaultHideWordBank} />
          Hide Wordbank
        </label>
        <div id="vu-word-bank-block" hidden={defaultHideWordBank}>
            <h2>Word Bank</h2>
            <p id="vu-word-bank" class="word-bank">{puzzle.bankWords.join(" | ")}</p>
        </div>

        <h2>Solved Verse</h2>
        <div class="solve-lines" aria-label="Space to write solved verse">
          <p class="solve-line"></p>
          <p class="solve-line"></p>
        </div>
        <p class="print-credit">
          Provided Freely with Love from BibleGames.Church <span aria-hidden="true">{"\u2764\uFE0F"}</span> Enjoy
        </p>
        <p class="answer-upside">Answer: {selectedVerse.reference} {selectedVerse.text}</p>
        <label class="answer-toggle no-print" for="vu-answer-toggle">
          <input id="vu-answer-toggle" type="checkbox" checked />
          Show Verse
        </label>
      </>
    ) : (
      <>
        <h1 class="title">Verse Unscramble</h1>
        <p class="muted">This chapter was not found.</p>
        <p><a href="/">Return to chapter picker</a></p>
      </>
    )}
  </section>
</Main>

<script
  is:inline
  define:vars={{ books, difficulty, selectedBookCode, selectedChapter, verseOptions, selectedVerseKey, defaultClueCount }}
>
  const vuBooks = Array.isArray(books) ? books : [];
  const vuDifficulty = String(difficulty || "medium");
  const ANSWER_TOGGLE_STORAGE_KEY = "bg:show-verse";
  const vuVerses = Array.isArray(verseOptions) ? verseOptions : [];
  const vuInitialVerseKey = String(selectedVerseKey || "");
  const vuTestamentSelect = document.getElementById("vu-testament-select");
  const vuBookSelect = document.getElementById("vu-book-select");
  const vuChapterSelect = document.getElementById("vu-chapter-select");
  const vuVerseSelect = document.getElementById("vu-verse-select");
  const vuClueCountSelect = document.getElementById("vu-clue-count-select");
  const vuHideWordBankToggle = document.getElementById("vu-hide-word-bank");
  const vuGrid = document.getElementById("vu-unscramble-grid");
  const vuWordBankBlock = document.getElementById("vu-word-bank-block");
  const vuWordBank = document.getElementById("vu-word-bank");
  const vuAnswerToggle = document.getElementById("vu-answer-toggle");
  const vuAnswerUpside = document.querySelector(".answer-upside");
  const keepVerseLinks = Array.from(document.querySelectorAll("[data-keep-verse-link]"));

  function normalizeVuTestamentFilter(value) {
    return value === "ot" || value === "nt" ? value : "all";
  }

  function currentVuTestamentFilter() {
    return normalizeVuTestamentFilter(new URLSearchParams(window.location.search).get("testament"));
  }

  function filteredVuBooks(testamentOverride) {
    const testament = normalizeVuTestamentFilter(
      testamentOverride || (vuTestamentSelect && "value" in vuTestamentSelect ? vuTestamentSelect.value : currentVuTestamentFilter())
    );
    if (testament === "ot" || testament === "nt") {
      return vuBooks.filter((book) => book.testament === testament);
    }
    return vuBooks;
  }

  function buildVuBookOptions(keepBookCode, testamentOverride) {
    if (!vuBookSelect) {
      return "";
    }
    const filteredBooks = filteredVuBooks(testamentOverride);
    const fallback = filteredBooks[0] ?? vuBooks[0];
    const hasKeepBook = filteredBooks.some((book) => book.code === keepBookCode);
    const bookToUse = hasKeepBook ? keepBookCode : fallback?.code ?? "gen";
    vuBookSelect.innerHTML = "";
    for (const book of filteredBooks) {
      const option = document.createElement("option");
      option.value = book.code;
      option.textContent = book.name;
      option.selected = book.code === bookToUse;
      vuBookSelect.appendChild(option);
    }
    return bookToUse;
  }

  function buildVuChapterOptions(bookCode, keepChapter) {
    if (!vuChapterSelect) {
      return;
    }
    const active = vuBooks.find((book) => book.code === bookCode) ?? vuBooks[0];
    const maxChapters = active?.chapterCount ?? 1;
    const chapterToUse = Math.min(Math.max(Number(keepChapter || 1), 1), maxChapters);
    vuChapterSelect.innerHTML = "";
    for (let chapter = 1; chapter <= maxChapters; chapter += 1) {
      const option = document.createElement("option");
      option.value = String(chapter);
      option.textContent = String(chapter);
      if (chapter === chapterToUse) {
        option.selected = true;
      }
      vuChapterSelect.appendChild(option);
    }
  }

  function selectedVuChapterPath(testamentOverride) {
    if (!vuBookSelect || !vuChapterSelect) {
      return "";
    }
    const bookCode = vuBookSelect.value || "gen";
    const chapter = vuChapterSelect.value || "1";
    const params = new URLSearchParams();
    const testament = normalizeVuTestamentFilter(
      testamentOverride || (vuTestamentSelect && "value" in vuTestamentSelect ? vuTestamentSelect.value : currentVuTestamentFilter())
    );
    if (testament === "ot" || testament === "nt") {
      params.set("testament", testament);
    }
    const query = params.toString();
    return `/games/verse-unscramble/${vuDifficulty}/${bookCode}/${chapter}${query ? `?${query}` : ""}`;
  }

  function selectedVuPathWithVerseOne(testamentOverride) {
    if (!vuBookSelect) {
      return "";
    }
    const bookCode = vuBookSelect.value || "gen";
    const basePath = `/games/verse-unscramble/${vuDifficulty}/${bookCode}/1`;
    const params = new URLSearchParams();
    params.set("verse", `${bookCode}.1.1`);
    const testament = normalizeVuTestamentFilter(
      testamentOverride || (vuTestamentSelect && "value" in vuTestamentSelect ? vuTestamentSelect.value : currentVuTestamentFilter())
    );
    if (testament === "ot" || testament === "nt") {
      params.set("testament", testament);
    }
    return `${basePath}?${params.toString()}`;
  }

  function withVerseQuery(href, verseKey) {
    const url = new URL(href, window.location.origin);
    const testament = normalizeVuTestamentFilter(
      vuTestamentSelect && "value" in vuTestamentSelect ? vuTestamentSelect.value : currentVuTestamentFilter()
    );
    if (testament === "ot" || testament === "nt") {
      url.searchParams.set("testament", testament);
    } else {
      url.searchParams.delete("testament");
    }
    if (verseKey) {
      url.searchParams.set("verse", verseKey);
    } else {
      url.searchParams.delete("verse");
    }
    return `${url.pathname}${url.search}`;
  }

  function syncVerseLinks() {
    const verseKey = vuVerseSelect && "value" in vuVerseSelect ? vuVerseSelect.value : "";

    for (const link of keepVerseLinks) {
      if (!(link instanceof HTMLAnchorElement)) {
        continue;
      }
      link.setAttribute("href", withVerseQuery(link.getAttribute("href") || link.href, verseKey));
    }
  }

  function findVerseByKey(key) {
    return vuVerses.find((verse) => verse.key === key) ?? vuVerses[0] ?? null;
  }

  function createSeededRandom(seedText) {
    let hash = 2166136261;
    for (let i = 0; i < seedText.length; i += 1) {
      hash ^= seedText.charCodeAt(i);
      hash = Math.imul(hash, 16777619);
    }
    return () => {
      hash += 0x6d2b79f5;
      let temp = Math.imul(hash ^ (hash >>> 15), 1 | hash);
      temp ^= temp + Math.imul(temp ^ (temp >>> 7), 61 | temp);
      return ((temp ^ (temp >>> 14)) >>> 0) / 4294967296;
    };
  }

  function shuffle(values, randomFn) {
    const list = [...values];
    for (let i = list.length - 1; i > 0; i -= 1) {
      const j = Math.floor(randomFn() * (i + 1));
      [list[i], list[j]] = [list[j], list[i]];
    }
    return list;
  }

  function scrambleWord(word, randomFn) {
    if (word.length < 3) {
      return word;
    }
    const letters = word.split("");
    for (let attempts = 0; attempts < 5; attempts += 1) {
      const shuffled = shuffle(letters, randomFn).join("");
      if (shuffled !== word) {
        return shuffled;
      }
    }
    return word.slice(1) + word[0];
  }

  function normalizeWords(text) {
    return (String(text || "").match(/[A-Za-z]+/g) ?? []).map((entry) => entry.toUpperCase());
  }

  function configForDifficulty() {
    if (vuDifficulty === "easy") {
      return { showFirstLetterHints: true };
    }
    if (vuDifficulty === "hard") {
      return { showFirstLetterHints: false };
    }
    return { showFirstLetterHints: false };
  }

  function selectedClueCount() {
    const raw = vuClueCountSelect && "value" in vuClueCountSelect ? Number(vuClueCountSelect.value) : Number(defaultClueCount || 0);
    return Number.isFinite(raw) ? Math.min(5, Math.max(0, Math.floor(raw))) : Number(defaultClueCount || 0);
  }

  function pickHintIndexes(answer, randomFn, clueCount) {
    if (!answer.length || clueCount <= 0) {
      return [];
    }
    const indexes = Array.from({ length: answer.length }, (_, index) => index);
    return shuffle(indexes, randomFn).slice(0, Math.min(clueCount, answer.length));
  }

  function buildPuzzleForVerse(verse) {
    const config = configForDifficulty();
    const clueCount = selectedClueCount();
    const words = normalizeWords(verse.text);
    const orderedWords = words.length ? words : ["BIBLE", "VERSE", "TRUTH"];
    const puzzleWords =
      vuDifficulty === "medium" || vuDifficulty === "hard"
        ? shuffle([...orderedWords], createSeededRandom(`${verse.key}|${vuDifficulty}|order`))
        : orderedWords;
    const random = createSeededRandom(`${verse.key}|${vuDifficulty}|unscramble`);
    const hintRandom = createSeededRandom(`${verse.key}|${vuDifficulty}|hints`);

    const items = puzzleWords.map((answer, index) => {
      const hintIndex = answer.length ? Math.floor(hintRandom() * answer.length) : 0;
      const hintIndexes = clueCount === 1 ? [hintIndex] : pickHintIndexes(answer, hintRandom, clueCount);
      return {
        index: index + 1,
        answer,
        scrambled: scrambleWord(answer, random),
        length: answer.length,
        firstLetter: answer[0] || "",
        hintIndex,
        hintLetter: answer[hintIndex] || "",
        hintIndexes,
      };
    });

    const bankWords = shuffle(
      items.map((item) => item.answer),
      createSeededRandom(`${verse.key}|${vuDifficulty}|bank`)
    );

    return { config, items, bankWords };
  }

  function createAnswerSlots(entry, showHints) {
    const hintIndexes = new Set(Array.isArray(entry.hintIndexes) ? entry.hintIndexes : []);
    return Array.from({ length: entry.length }, (_, index) => {
      if (showHints && hintIndexes.has(index)) {
        return `<span class="hint-slot">${entry.answer[index] || ""}</span>`;
      }
      return '<span class="answer-slot" aria-hidden="true"></span>';
    }).join("");
  }

  function syncWordBankVisibility() {
    if (!vuWordBankBlock) {
      return;
    }
    const hide = vuHideWordBankToggle && "checked" in vuHideWordBankToggle ? vuHideWordBankToggle.checked : false;
    vuWordBankBlock.hidden = hide;
  }

  function renderUnscramble(verse) {
    if (!verse || !vuGrid) {
      return;
    }

    const built = buildPuzzleForVerse(verse);
    const showFirstHints = selectedClueCount() > 0;
    const itemsHtml = built.items
      .map((entry) => {
        const lineClass =
          entry.length >= 12
            ? "answer-line ultra"
            : entry.length >= 10
              ? "answer-line tight"
              : entry.length >= 8
              ? "answer-line compact"
              : "answer-line";
        return `<li class="unscramble-item"><div class="scramble-cell">${entry.scrambled}</div><div class="answer-cell"><span class="${lineClass}">${createAnswerSlots(entry, showFirstHints)}</span></div></li>`;
      })
      .join("");

    vuGrid.innerHTML = itemsHtml;

    if (vuWordBank) {
      vuWordBank.textContent = built.bankWords.join(" | ");
    }
    syncWordBankVisibility();

    if (vuAnswerUpside) {
      vuAnswerUpside.textContent = `Answer: ${verse.reference} ${verse.text}`;
    }
  }

  function syncAnswerVisibility() {
    if (!vuAnswerUpside) {
      return;
    }
    const show = !vuAnswerToggle || !("checked" in vuAnswerToggle) ? true : vuAnswerToggle.checked;
    vuAnswerUpside.style.display = show ? "" : "none";
  }

  function loadAnswerToggleState() {
    if (!vuAnswerToggle || !("checked" in vuAnswerToggle)) {
      return;
    }
    try {
      const saved = localStorage.getItem(ANSWER_TOGGLE_STORAGE_KEY);
      if (saved === "0" || saved === "1") {
        vuAnswerToggle.checked = saved === "1";
      }
    } catch {
      // Ignore storage errors and keep the markup default.
    }
  }

  if (vuBookSelect) {
    vuBookSelect.addEventListener("change", () => {
      buildVuChapterOptions(vuBookSelect.value, 1);
      const nextPath = selectedVuPathWithVerseOne();
      if (nextPath) {
        window.location.href = nextPath;
      }
    });
  }

  if (vuTestamentSelect) {
    vuTestamentSelect.addEventListener("change", (event) => {
      const testament = normalizeVuTestamentFilter(
        event.currentTarget && "value" in event.currentTarget ? event.currentTarget.value : "all"
      );
      const bookToUse = buildVuBookOptions(vuBookSelect && "value" in vuBookSelect ? vuBookSelect.value : "", testament);
      buildVuChapterOptions(bookToUse, 1);
      const nextPath = selectedVuPathWithVerseOne(testament);
      if (nextPath) {
        window.location.href = nextPath;
      }
    });
  }

  if (vuChapterSelect) {
    vuChapterSelect.addEventListener("change", () => {
      const nextPath = selectedVuChapterPath();
      if (nextPath) {
        window.location.href = nextPath;
      }
    });
  }

  if (vuVerseSelect) {
    vuVerseSelect.addEventListener("change", () => {
      const chosenVerse = findVerseByKey(vuVerseSelect.value);
      if (chosenVerse) {
        renderUnscramble(chosenVerse);
      }
      syncVerseLinks();
      const nextUrl = withVerseQuery(window.location.pathname + window.location.search, vuVerseSelect.value || "");
      history.replaceState(null, "", nextUrl);
    });
  }

  if (vuClueCountSelect) {
    vuClueCountSelect.addEventListener("change", () => {
      const activeKey = vuVerseSelect && "value" in vuVerseSelect ? vuVerseSelect.value : vuInitialVerseKey;
      const chosenVerse = findVerseByKey(activeKey);
      if (chosenVerse) {
        renderUnscramble(chosenVerse);
      }
    });
  }

  if (vuHideWordBankToggle) {
    vuHideWordBankToggle.addEventListener("change", syncWordBankVisibility);
  }

  if (vuAnswerToggle) {
    vuAnswerToggle.addEventListener("change", () => {
      try {
        localStorage.setItem(ANSWER_TOGGLE_STORAGE_KEY, vuAnswerToggle.checked ? "1" : "0");
      } catch {
        // Ignore storage errors; the current page state still updates.
      }
      syncAnswerVisibility();
    });
  }

  if (vuTestamentSelect) {
    vuTestamentSelect.value = currentVuTestamentFilter();
  }
  const initialVuBookCode = buildVuBookOptions(String(selectedBookCode || "gen"), currentVuTestamentFilter());
  buildVuChapterOptions(initialVuBookCode || String(selectedBookCode || "gen"), Number(selectedChapter || 1));
  loadAnswerToggleState();
  const urlVerse = new URLSearchParams(window.location.search).get("verse") || "";
  const startVerse = findVerseByKey(urlVerse || vuInitialVerseKey);
  if (vuVerseSelect && startVerse) {
    vuVerseSelect.value = startVerse.key;
  }
  if (startVerse) {
    renderUnscramble(startVerse);
  }
  syncVerseLinks();
  syncWordBankVisibility();
  syncAnswerVisibility();
</script>
