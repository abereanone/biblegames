---
import Main from "@/layouts/Main.astro";
import GameNav from "@/components/GameNav.astro";
import { coloringPages } from "@/data/coloringPages";
import { DIFFICULTIES, DIFFICULTY_LABELS } from "@/lib/games/difficulty";

const visibleColoringPages = coloringPages.filter((page) => page.display !== false);
---

<Main title="Coloring Pages | Bible Games">
  <GameNav />

  <section class="panel game-theme theme-coloring-pages">
    <h1 class="title">Coloring Pages</h1>
    <p class="subtitle">
      Printable Bible coloring pages for home, church, and Sunday school. Tap or click an image, then print from your browser. Make sure to check Landscape or Portrait as needed.
    </p>

    <div class="coloring-filter no-print" aria-label="Filter coloring pages by difficulty">
      {DIFFICULTIES.map((difficulty) => (
        <button type="button" class="btn alt" data-coloring-filter={difficulty}>
          {DIFFICULTY_LABELS[difficulty]}
        </button>
      ))}
    </div>

    <div class="coloring-grid">
      {visibleColoringPages.map((page) => (
        <article class="coloring-card" data-coloring-level={page.level ?? ""}>
          <a class="coloring-preview-link" href={page.printablePath} aria-label={`Open ${page.title} coloring page`}>
            <img class="coloring-preview" src={page.previewPath} alt="" loading="lazy" />
          </a>

          <div class="coloring-card-body">
            <h2>{page.title}{page.level ? ` (${page.level})` : ""}</h2>
            <p class="muted">{page.bibleReference}</p>
            <p>{page.description}</p>

          </div>
        </article>
      ))}
    </div>
  </section>
</Main>

<script>
  const filterButtons = document.querySelectorAll("[data-coloring-filter]");
  const coloringCards = document.querySelectorAll("[data-coloring-level]");

  function setColoringFilter(level) {
    for (const button of filterButtons) {
      button.classList.toggle("alt", button.getAttribute("data-coloring-filter") !== level);
      button.setAttribute("aria-pressed", String(level !== "" && button.getAttribute("data-coloring-filter") === level));
    }

    for (const card of coloringCards) {
      card.hidden = level !== "" && card.getAttribute("data-coloring-level") !== level;
    }
  }

  for (const button of filterButtons) {
    button.addEventListener("click", () => {
      const level = button.getAttribute("data-coloring-filter") || "";
      const isActive = button.getAttribute("aria-pressed") === "true";
      setColoringFilter(isActive ? "" : level);
    });
  }

  setColoringFilter("");
</script>

<style>
  .coloring-filter {
    margin-top: 1rem;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.65rem;
  }

  .coloring-grid {
    margin-top: 1rem;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 0.9rem;
  }

  .coloring-card {
    overflow: hidden;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: #fff;
  }

  .coloring-preview-link {
    display: block;
    color: inherit;
  }

  .coloring-preview {
    display: block;
    width: 100%;
    aspect-ratio: 8.5 / 11;
    object-fit: cover;
    background: #fff;
    border-bottom: 1px solid var(--line);
  }

  .coloring-card-body {
    padding: 0.85rem;
  }

  .coloring-card h2 {
    margin: 0;
    font-size: 1.18rem;
  }

  .coloring-card p {
    margin: 0.45rem 0;
  }

  .coloring-card .btn {
    margin-top: 0.4rem;
  }

  @media (max-width: 720px) {
    .coloring-filter {
      grid-template-columns: 1fr;
    }
  }
</style>
