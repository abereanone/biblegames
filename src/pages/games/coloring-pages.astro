---
import Main from "@/layouts/Main.astro";
import coloringPages from "@/data/coloringPages.json";
---

<Main title="Coloring Pages | Bible Games">
  <section class="panel no-print game-nav-panel game-theme theme-coloring-pages">
    <div class="button-row">
      <a class="btn game-btn" data-game="word-search" href="/">
        Word Search
      </a>
      <a class="btn game-btn" data-game="cryptogram" href="/games/cryptogram/medium/gen/1">
        Cryptogram
      </a>
      <a class="btn game-btn" data-game="verse-unscramble" href="/games/verse-unscramble/medium/gen/1">
        Verse Unscramble
      </a>
      <a class="btn game-btn" data-game="coloring-pages" href="/games/coloring-pages">
        Coloring Pages
      </a>
      <a class="btn game-btn" data-game="bible-wordle" href="/games/bible-wordle">
        Bible Verse Wordle
      </a>
    </div>
  </section>

  <section class="panel game-theme theme-coloring-pages">
    <h1 class="title">Coloring Pages</h1>
    <p class="subtitle">
      Printable Bible coloring pages for home, church, and Sunday school.
    </p>

    <div class="button-row">
      {coloringPages.map((page) => (
        <div class="panel" style="padding:0.75rem;">
          <h2>{page.title}</h2>
          <p class="muted">{page.bibleReference}</p>
          <p>{page.description}</p>

          <a class="btn" href={page.pdfPath} download>
            Download PDF
          </a>
        </div>
      ))}
    </div>
  </section>
</Main>
