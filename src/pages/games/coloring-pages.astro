---
import Main from "@/layouts/Main.astro";
import GameNav from "@/components/GameNav.astro";
import { coloringPages } from "@/data/coloringPages";
import { DIFFICULTIES, DIFFICULTY_LABELS } from "@/lib/games/difficulty";

const pathByDifficulty = {
  easy: "easyPath",
  medium: "mediumPath",
  hard: "hardPath",
} as const;

const coloringCards = coloringPages.flatMap((page) =>
  DIFFICULTIES.flatMap((difficulty) => {
    const path = page[pathByDifficulty[difficulty]];

    if (path === "") {
      return [];
    }

    return [{
      title: page.title,
      ref: page.ref,
      description: page.description,
      level: difficulty,
      path,
    }];
  }),
);
---

<Main title="Coloring Pages | Bible Games">
  <GameNav />

  <section class="panel game-theme theme-coloring-pages">
    <h1 class="title">Coloring Pages</h1>
    <p class="subtitle">
      Printable Bible coloring pages for home, church, and Sunday school. Tap or click an image, then print from your browser. Make sure to check Landscape or Portrait as needed. Tap a difficulty level to filter, or tap it again to show all.
    </p>

    <label class="coloring-ref-picker no-print">
      <span>Bible reference</span>
      <select data-coloring-ref>
        <option value="">All references</option>
        {coloringPages.map((page) => (
          <option value={page.ref}>{page.ref}</option>
        ))}
      </select>
    </label>

    <div class="coloring-filter no-print" aria-label="Filter coloring pages by difficulty">
      {DIFFICULTIES.map((difficulty) => (
        <button type="button" class="btn alt" data-coloring-filter={difficulty}>
          {DIFFICULTY_LABELS[difficulty]}
        </button>
      ))}
    </div>

    <div class="coloring-grid">
      {coloringCards.map((page) => (
        <article class="coloring-card" data-coloring-level={page.level} data-coloring-card-ref={page.ref}>
          <a class="coloring-preview-link" target="_blank" href={page.path} aria-label={`Open ${page.title} coloring page`}>
            <img class="coloring-preview" src={page.path} alt="" loading="lazy" />
          </a>

          <div class="coloring-card-body">
            <h2>{page.title} ({DIFFICULTY_LABELS[page.level]})</h2>
            <p class="muted">{page.ref}</p>
            <p>{page.description}</p>

          </div>
        </article>
      ))}
    </div>
  </section>
</Main>

<script>
  const filterButtons = document.querySelectorAll("[data-coloring-filter]");
  const refSelect = document.querySelector("[data-coloring-ref]");
  const coloringCards = document.querySelectorAll("[data-coloring-level]");
  let selectedLevel = "";
  let selectedRef = "";

  function applyColoringFilters() {
    for (const button of filterButtons) {
      button.classList.toggle("alt", button.getAttribute("data-coloring-filter") !== selectedLevel);
      button.setAttribute("aria-pressed", String(selectedLevel !== "" && button.getAttribute("data-coloring-filter") === selectedLevel));
    }

    for (const card of coloringCards) {
      const matchesLevel = selectedLevel === "" || card.getAttribute("data-coloring-level") === selectedLevel;
      const matchesRef = selectedRef === "" || card.getAttribute("data-coloring-card-ref") === selectedRef;
      card.hidden = !matchesLevel || !matchesRef;
    }
  }

  for (const button of filterButtons) {
    button.addEventListener("click", () => {
      const level = button.getAttribute("data-coloring-filter") || "";
      const isActive = button.getAttribute("aria-pressed") === "true";
      selectedLevel = isActive ? "" : level;
      applyColoringFilters();
    });
  }

  refSelect?.addEventListener("change", (event) => {
    selectedRef = event.currentTarget instanceof HTMLSelectElement ? event.currentTarget.value : "";
    applyColoringFilters();
  });

  applyColoringFilters();
</script>

<style>
  .coloring-ref-picker {
    margin-top: 1rem;
    display: grid;
    gap: 0.35rem;
    max-width: 22rem;
    font-weight: 700;
  }

  .coloring-ref-picker select {
    width: 100%;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: #fff;
    color: inherit;
    font: inherit;
    padding: 0.65rem 0.75rem;
  }

  .coloring-filter {
    margin-top: 1rem;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.65rem;
  }

  .coloring-grid {
    margin-top: 1rem;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 0.9rem;
  }

  .coloring-card {
    overflow: hidden;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: #fff;
  }

  .coloring-preview-link {
    display: block;
    color: inherit;
  }

  .coloring-preview {
    display: block;
    width: 100%;
    aspect-ratio: 8.5 / 11;
    object-fit: cover;
    background: #fff;
    border-bottom: 1px solid var(--line);
  }

  .coloring-card-body {
    padding: 0.85rem;
  }

  .coloring-card h2 {
    margin: 0;
    font-size: 1.18rem;
  }

  .coloring-card p {
    margin: 0.45rem 0;
  }

  .coloring-card .btn {
    margin-top: 0.4rem;
  }

  @media (max-width: 720px) {
    .coloring-filter {
      grid-template-columns: 1fr;
    }
  }
</style>
