---
import Main from "@/layouts/Main.astro";
import { getBibleData, getChapter } from "@/lib/bible/data";
import { DIFFICULTIES, parseDifficulty, type PuzzleDifficulty } from "@/lib/games/difficulty";
import { buildWordSearch } from "@/lib/games/wordSearch";

export async function getStaticPaths() {
  const bible = await getBibleData();

  return DIFFICULTIES.flatMap((difficulty) =>
    bible.books.flatMap((book) =>
      Array.from({ length: book.chapterCount }, (_, index) => ({
        params: {
          difficulty,
          book: book.code,
          chapter: String(index + 1),
        },
      }))
    )
  );
}

const difficulty = parseDifficulty(String(Astro.params.difficulty ?? "medium"));
const rawBook = String(Astro.params.book ?? "").toLowerCase();
const rawChapter = Number(Astro.params.chapter ?? "0");
const chapterData = await getChapter(rawBook, rawChapter);
const bibleData = await getBibleData();
const books = bibleData.books;
const selectedBookCode = chapterData?.bookCode ?? rawBook;
const selectedBook = books.find((book) => book.code === selectedBookCode) ?? books[0];
const selectedChapter = chapterData?.chapter ?? 1;

const puzzle = chapterData ? buildWordSearch(chapterData.verses.map((verse) => verse.text), difficulty) : null;
const title = chapterData
  ? `Word Search (${difficulty}) | ${chapterData.bookName} ${chapterData.chapter}`
  : "Word Search | Chapter Not Found";

const difficultyLabel = difficulty.charAt(0).toUpperCase() + difficulty.slice(1);
const difficultyLinks = DIFFICULTIES.map((value) => ({
  value,
  label: value.charAt(0).toUpperCase() + value.slice(1),
  href: chapterData ? `/games/word-search/${value}/${chapterData.bookCode}/${chapterData.chapter}` : "/",
}));

function helperText(value: PuzzleDifficulty): string {
  if (value === "easy") {
    return "Shorter words and forward-only directions.";
  }
  if (value === "hard") {
    return "More words, larger grid, and all directions.";
  }
  return "Balanced word count and diagonal directions.";
}

function puzzleSourceLine(value: PuzzleDifficulty, bookName: string, chapter: number): string {
  if (value === "hard") {
    return "guess the book and chapter?";
  }
  if (value === "medium") {
    return `${bookName} __`;
  }
  return `${bookName} ${chapter}`;
}
---

<Main title={title}>
  {chapterData && puzzle ? (
    <section class="panel no-print game-nav-panel game-theme theme-word-search">
      <div class="button-row">
        <a
          class="btn game-btn"
          data-game="word-search"
          href={`/games/word-search/${difficulty}/${chapterData.bookCode}/${chapterData.chapter}`}
        >
          Word Search
        </a>
        <a
          class="btn game-btn"
          data-game="cryptogram"
          href={`/games/cryptogram/${difficulty}/${chapterData.bookCode}/${chapterData.chapter}`}
        >
          Cryptogram
        </a>
        <a
          class="btn game-btn"
          data-game="verse-unscramble"
          href={`/games/verse-unscramble/${difficulty}/${chapterData.bookCode}/${chapterData.chapter}`}
        >
          Verse Unscramble
        </a>
        <a class="btn game-btn" data-game="bible-wordle" href="/games/bible-wordle">
          Bible Verse Wordle
        </a>
      </div>
    </section>
  ) : null}

  <section class="panel game-theme theme-word-search">
    {chapterData && puzzle ? (
      <>
        <h1 class="title">Word Search</h1>
        <p class="subtitle">{puzzleSourceLine(difficulty, chapterData.bookName, chapterData.chapter)} | {difficultyLabel}</p>
        <p class="muted no-print">{helperText(difficulty)}</p>

        <div class="button-row no-print">
          {difficultyLinks.map((entry) => (
            <a class={`btn ${entry.value === difficulty ? "" : "alt"}`} href={entry.href}>{entry.label}</a>
          ))}
        </div>

        <div class="field-grid chapter-jump-grid no-print">
          <div>
            <select id="ws-book-select" name="ws-book">
              {books.map((book) => (
                <option value={book.code} selected={book.code === selectedBook?.code}>{book.name}</option>
              ))}
            </select>
          </div>
          <div>
            <select id="ws-chapter-select" name="ws-chapter">
              {Array.from({ length: selectedBook?.chapterCount ?? 1 }, (_, index) => {
                const chapter = index + 1;
                return <option value={chapter} selected={chapter === selectedChapter}>{chapter}</option>;
              })}
            </select>
          </div>
          <div class="chapter-jump-spacer" aria-hidden="true"></div>
        </div>
        <div class="button-row no-print">
          <button type="button" onclick="window.__bgPrint ? window.__bgPrint(event) : window.print()">Print this Puzzle!</button>
        </div>
        <div class="word-grid-wrap">
          <table class="word-grid" aria-label="Word search puzzle grid">
            <tbody>
              {puzzle.grid.map((row) => (
                <tr>
                  {row.map((cell) => (
                    <td>{cell}</td>
                  ))}
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <h2>Find These Words</h2>
        <ul class="word-list">
          {puzzle.words.map((word) => (
            <li>{word}</li>
          ))}
        </ul>
        <p class="print-credit">
          Provided Freely with Love from BibleGames.Church <span aria-hidden="true">{"\u2764\uFE0F"}</span> Enjoy
        </p>
        {difficulty === "medium" || difficulty === "hard" ? (
          <>
            <p id="ws-answer-upside" class="answer-upside">Answer: {chapterData.bookName} {chapterData.chapter}</p>
            <label class="answer-toggle no-print" for="ws-answer-toggle">
              <input id="ws-answer-toggle" type="checkbox" checked />
              Show Verse
            </label>
          </>
        ) : null}
      </>
    ) : (
      <>
        <h1 class="title">Word Search</h1>
        <p class="muted">This chapter was not found.</p>
        <p><a href="/">Return to chapter picker</a></p>
      </>
    )}
  </section>
</Main>

<script is:inline define:vars={{ books, difficulty, selectedBookCode, selectedChapter }}>
  const wsBooks = Array.isArray(books) ? books : [];
  const wsDifficulty = String(difficulty || "medium");
  const ANSWER_TOGGLE_STORAGE_KEY = "bg:show-verse";
  const wsBookSelect = document.getElementById("ws-book-select");
  const wsChapterSelect = document.getElementById("ws-chapter-select");
  const wsAnswerToggle = document.getElementById("ws-answer-toggle");
  const wsAnswerUpside = document.getElementById("ws-answer-upside");

  function buildWsChapterOptions(bookCode, keepChapter) {
    if (!wsChapterSelect) {
      return;
    }
    const active = wsBooks.find((book) => book.code === bookCode) ?? wsBooks[0];
    const maxChapters = active?.chapterCount ?? 1;
    const chapterToUse = Math.min(Math.max(Number(keepChapter || 1), 1), maxChapters);
    wsChapterSelect.innerHTML = "";
    for (let chapter = 1; chapter <= maxChapters; chapter += 1) {
      const option = document.createElement("option");
      option.value = String(chapter);
      option.textContent = String(chapter);
      if (chapter === chapterToUse) {
        option.selected = true;
      }
      wsChapterSelect.appendChild(option);
    }
  }

  function selectedWsChapterPath() {
    if (!wsBookSelect || !wsChapterSelect) {
      return "";
    }
    const bookCode = wsBookSelect.value || "gen";
    const chapter = wsChapterSelect.value || "1";
    return `/games/word-search/${wsDifficulty}/${bookCode}/${chapter}`;
  }

  if (wsBookSelect) {
    wsBookSelect.addEventListener("change", () => {
      buildWsChapterOptions(wsBookSelect.value, 1);
      const nextPath = selectedWsChapterPath();
      if (nextPath) {
        window.location.href = nextPath;
      }
    });
  }

  if (wsChapterSelect) {
    wsChapterSelect.addEventListener("change", () => {
      const nextPath = selectedWsChapterPath();
      if (nextPath) {
        window.location.href = nextPath;
      }
    });
  }

  function syncAnswerVisibility() {
    if (!wsAnswerUpside) {
      return;
    }
    const show = !wsAnswerToggle || !("checked" in wsAnswerToggle) ? true : wsAnswerToggle.checked;
    wsAnswerUpside.style.display = show ? "" : "none";
  }

  function loadAnswerToggleState() {
    if (!wsAnswerToggle || !("checked" in wsAnswerToggle)) {
      return;
    }
    try {
      const saved = localStorage.getItem(ANSWER_TOGGLE_STORAGE_KEY);
      if (saved === "0" || saved === "1") {
        wsAnswerToggle.checked = saved === "1";
      }
    } catch {
      // Ignore storage errors and keep the markup default.
    }
  }

  if (wsAnswerToggle) {
    wsAnswerToggle.addEventListener("change", () => {
      try {
        localStorage.setItem(ANSWER_TOGGLE_STORAGE_KEY, wsAnswerToggle.checked ? "1" : "0");
      } catch {
        // Ignore storage errors; the current page state still updates.
      }
      syncAnswerVisibility();
    });
  }

  buildWsChapterOptions(String(selectedBookCode || "gen"), Number(selectedChapter || 1));
  loadAnswerToggleState();
  syncAnswerVisibility();
</script>
