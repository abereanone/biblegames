---
import Main from "@/layouts/Main.astro";
import { getBibleData } from "@/lib/bible/data";
import { DIFFICULTIES, DIFFICULTY_LABELS } from "@/lib/games/difficulty";
import GameNav from "@/components/GameNav.astro";

const bible = await getBibleData();
const books = bible.books;
const firstBook = books[0];
---

<Main title="Bible Games | Fun games while learning!">
  <section class="panel">
    <h1 class="title">Printable Bible Games</h1>
    <p class="subtitle">
      Pick a chapter, then tap the button for the game you want to play.
    </p>

    {!bible.hasData ? (
      <>
        <p class="muted">
          No local Bible copy found at <code>{bible.sourcePath}</code>.
        </p>
        <p class="muted">
          Copy your BSB file into <code>data/bsb.json</code>, then start dev with <code>npm run dev</code>.
        </p>
      </>
    ) : (
      <>
        <div class="field-grid home-picker-row">
          <div>
            <label for="testament-select">OT / NT</label>
            <select id="testament-select" name="testament" aria-label="Filter books by testament">
              <option value="">All</option>
              <option value="ot">OT</option>
              <option value="nt">NT</option>
            </select>
          </div>
          <div>
            <label for="book-select">Bible Book</label>
            <select id="book-select" name="book">
              {books.map((book) => (
                <option value={book.code} data-chapters={book.chapterCount} data-testament={book.testament}>
                  {book.name}
                </option>
              ))}
            </select>
          </div>
          <div>
            <label for="chapter-select">Chapter</label>
            <select id="chapter-select" name="chapter">
              {Array.from({ length: firstBook?.chapterCount ?? 1 }, (_, index) => (
                <option value={index + 1}>{index + 1}</option>
              ))}
            </select>
          </div>
          <div>
            <label for="difficulty-select">Difficulty</label>
            <select id="difficulty-select" name="difficulty">
              {DIFFICULTIES.map((difficulty) => (
                <option value={difficulty} selected={difficulty === "medium"}>
                  {DIFFICULTY_LABELS[difficulty]}
                </option>
              ))}
            </select>
          </div>
        </div>

        <GameNav collapsedOnMobile={false} />

        <h2>Quick Start</h2>
        <div class="button-row">
          <a
            id="random-word-search-link"
            class="btn game-btn"
            data-game="word-search"
            href={`/games/word-search/medium/${firstBook?.code ?? "gen"}/1`}
          >
            Random Word Search
          </a>
          <a
            id="random-cryptogram-link"
            class="btn game-btn"
            data-game="cryptogram"
            href={`/games/cryptogram/medium/${firstBook?.code ?? "gen"}/1`}
          >
            Random Cryptogram
          </a>
          <a
            id="random-verse-unscramble-link"
            class="btn game-btn"
            data-game="verse-unscramble"
            href={`/games/verse-unscramble/medium/${firstBook?.code ?? "gen"}/1`}
          >
            Random Verse Unscramble
          </a>
          <a class="btn game-btn" data-game="bible-wordle" href="/games/bible-wordle">
            Bible Verse Wordle Today
          </a>
        </div>
      </>
    )}
  </section>
</Main>

<script is:inline define:vars={{ books }}>
  const DIFFICULTY_STORAGE_KEY = "bg:difficulty";
  const safeBooks = Array.isArray(books) ? books : [];
  const testamentSelect = document.getElementById("testament-select");
  const bookSelect = document.getElementById("book-select");
  const chapterSelect = document.getElementById("chapter-select");
  const difficultySelect = document.getElementById("difficulty-select");
  const randomWordLink = document.getElementById("random-word-search-link");
  const randomCryptLink = document.getElementById("random-cryptogram-link");
  const randomVerseUnscrambleLink = document.getElementById("random-verse-unscramble-link");

  function buildChapterOptions(chapterCount, selectedChapter = 1) {
    if (!chapterSelect) {
      return;
    }
    chapterSelect.innerHTML = "";
    for (let chapter = 1; chapter <= chapterCount; chapter += 1) {
      const option = document.createElement("option");
      option.value = String(chapter);
      option.textContent = String(chapter);
      if (chapter === selectedChapter) {
        option.selected = true;
      }
      chapterSelect.appendChild(option);
    }
  }

  function filteredBooks() {
    const testament = testamentSelect && "value" in testamentSelect ? testamentSelect.value : "";
    if (testament === "ot" || testament === "nt") {
      return safeBooks.filter((book) => book.testament === testament);
    }
    return safeBooks;
  }

  function buildBookOptions(keepBookCode) {
    if (!bookSelect) {
      return safeBooks[0]?.code ?? "gen";
    }
    const booksToShow = filteredBooks();
    const fallback = booksToShow[0] ?? safeBooks[0];
    const hasKeepBook = booksToShow.some((book) => book.code === keepBookCode);
    const bookToUse = hasKeepBook ? keepBookCode : fallback?.code ?? "gen";
    bookSelect.innerHTML = "";
    for (const book of booksToShow) {
      const option = document.createElement("option");
      option.value = book.code;
      option.textContent = book.name;
      option.dataset.chapters = String(book.chapterCount);
      option.dataset.testament = book.testament;
      option.selected = book.code === bookToUse;
      bookSelect.appendChild(option);
    }
    return bookToUse;
  }

  function filteredBooks() {
    const testament = testamentSelect && "value" in testamentSelect ? testamentSelect.value : "";
    if (testament === "ot" || testament === "nt") {
      return safeBooks.filter((book) => book.testament === testament);
    }
    return safeBooks;
  }

  function buildBookOptions(keepBookCode) {
    if (!bookSelect) {
      return safeBooks[0]?.code ?? "gen";
    }
    const book = bookSelect.value;
    const chapter = chapterSelect.value || "1";
    const difficulty = difficultySelect?.value || "medium";
    wordLink.setAttribute("href", `/games/word-search/${difficulty}/${book}/${chapter}`);
    cryptLink.setAttribute("href", `/games/cryptogram/${difficulty}/${book}/${chapter}`);
    verseUnscrambleLink.setAttribute("href", `/games/verse-unscramble/${difficulty}/${book}/${chapter}`);
  }

  function randomChapterPath(game) {
    const difficulty = difficultySelect?.value || "medium";
    const pool = filteredBooks().filter((entry) => Number(entry.chapterCount) > 0);
    const chosenBook = pool[Math.floor(Math.random() * pool.length)] || pool[0];
    if (!chosenBook) {
      return `/`;
    }
    const chapter = 1 + Math.floor(Math.random() * chosenBook.chapterCount);
    return `/games/${game}/${difficulty}/${chosenBook.code}/${chapter}`;
  }

  function syncQuickStartLinks() {
    if (randomWordLink) {
      randomWordLink.setAttribute("href", randomChapterPath("word-search"));
    }
    if (randomCryptLink) {
      randomCryptLink.setAttribute("href", randomChapterPath("cryptogram"));
    }
    if (randomVerseUnscrambleLink) {
      randomVerseUnscrambleLink.setAttribute("href", randomChapterPath("verse-unscramble"));
    }
  }

  if (bookSelect) {
    bookSelect.addEventListener("change", () => {
      const selected = safeBooks.find((entry) => entry.code === bookSelect.value);
      buildChapterOptions(selected?.chapterCount ?? 1, 1);
    });
  }

  if (testamentSelect) {
    testamentSelect.addEventListener("change", () => {
      const bookToUse = buildBookOptions(bookSelect && "value" in bookSelect ? bookSelect.value : "");
      const selected = safeBooks.find((entry) => entry.code === bookToUse);
      buildChapterOptions(selected?.chapterCount ?? 1, 1);
      syncQuickStartLinks();
    });
  }

  if (testamentSelect) {
    testamentSelect.addEventListener("change", () => {
      const bookToUse = buildBookOptions(bookSelect && "value" in bookSelect ? bookSelect.value : "");
      const selected = safeBooks.find((entry) => entry.code === bookToUse);
      buildChapterOptions(selected?.chapterCount ?? 1, 1);
      syncQuickStartLinks();
    });
  }

  if (testamentSelect) {
    testamentSelect.addEventListener("change", () => {
      const bookToUse = buildBookOptions(bookSelect && "value" in bookSelect ? bookSelect.value : "");
      const selected = safeBooks.find((entry) => entry.code === bookToUse);
      buildChapterOptions(selected?.chapterCount ?? 1, 1);
      syncQuickStartLinks();
    });
  }

  if (difficultySelect) {
    difficultySelect.addEventListener("change", () => {
      try {
        localStorage.setItem(DIFFICULTY_STORAGE_KEY, difficultySelect.value || "medium");
      } catch {
        // Ignore storage errors; links still sync in-memory.
      }
      syncQuickStartLinks();
    });
  }

  if (randomWordLink) {
    randomWordLink.addEventListener("click", () => {
      randomWordLink.setAttribute("href", randomChapterPath("word-search"));
    });
  }

  if (randomCryptLink) {
    randomCryptLink.addEventListener("click", () => {
      randomCryptLink.setAttribute("href", randomChapterPath("cryptogram"));
    });
  }

  if (randomVerseUnscrambleLink) {
    randomVerseUnscrambleLink.addEventListener("click", () => {
      randomVerseUnscrambleLink.setAttribute("href", randomChapterPath("verse-unscramble"));
    });
  }

  if (difficultySelect) {
    try {
      const savedDifficulty = localStorage.getItem(DIFFICULTY_STORAGE_KEY) || "";
      const hasSavedDifficulty = ["easy", "medium", "hard"].includes(savedDifficulty);
      if (hasSavedDifficulty) {
        difficultySelect.value = savedDifficulty;
      }
    } catch {
      // Ignore storage errors and keep the markup default.
    }
  }

  syncQuickStartLinks();
</script>
